# Copy to docker/.env and fill in. docker/.env is gitignored.
# Auth is passed at runtime and is never baked into the image.

# Claude Code: API-key auth (alternative: `claude login` inside the container).
ANTHROPIC_API_KEY=

# Codex CLI: API-key auth (alternative: `codex login` inside the container).
OPENAI_API_KEY=

# GitHub token for forge-cli / gh inside the container (optional).
GH_TOKEN=
