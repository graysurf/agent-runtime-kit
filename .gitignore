build/
# Drift fixtures must ship their pre-rendered build/ trees so they reproduce
# hermetically on fresh clones (CI included).
!tests/drift/*/build/
!tests/drift/*/build/**
*.local.*
.env
.env.*
secrets/
secrets.*.yaml
auth.json
.credentials*
**/sessions/
**/history/
**/cache/
.private/
.claude/
backup-*.zip
