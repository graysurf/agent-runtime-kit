{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime-kit.local/schemas/surfaces.schema.json",
  "title": "surfaces.yaml",
  "description": "Cross-product SUPPORT_MATRIX row registry. Records the 17 canonical harness surfaces and the per-product state, mechanism, source artifacts, version floors, source pointers, and typed acceptance entries that render the root SUPPORT_MATRIX.md view.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "render", "surfaces"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "render": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "root_view", "output"],
      "properties": {
        "target": {
          "type": "string",
          "const": "support-matrix"
        },
        "root_view": {
          "type": "string",
          "const": "SUPPORT_MATRIX.md"
        },
        "output": {
          "type": "string",
          "const": "build/shared/SUPPORT_MATRIX.md"
        }
      }
    },
    "surfaces": {
      "type": "array",
      "description": "Canonical SUPPORT_MATRIX surfaces. The first version intentionally carries the existing 17-surface set.",
      "minItems": 17,
      "items": { "$ref": "#/$defs/surface" }
    }
  },
  "$defs": {
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "ordinal", "name", "products"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "ordinal": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "products": {
          "type": "object",
          "additionalProperties": false,
          "required": ["codex", "claude"],
          "properties": {
            "codex": { "$ref": "#/$defs/productSurface" },
            "claude": { "$ref": "#/$defs/productSurface" }
          }
        }
      }
    },
    "productSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "mechanism",
        "source_artifacts",
        "min_product",
        "min_nils_cli",
        "acceptance",
        "source_manifest"
      ],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "shipped",
            "partial",
            "planned-not-shipped",
            "not-shipped",
            "not-applicable"
          ]
        },
        "mechanism": {
          "type": "string",
          "minLength": 1
        },
        "source_artifacts": {
          "type": "array",
          "description": "Repo-relative source artifacts. Empty means the rendered table displays no artifact for this product surface.",
          "items": { "type": "string", "minLength": 1 }
        },
        "min_product": {
          "type": "string",
          "minLength": 1
        },
        "min_nils_cli": {
          "type": "string",
          "minLength": 1
        },
        "acceptance": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/acceptance" },
          "allOf": [
            {
              "contains": {
                "type": "object",
                "required": ["kind"],
                "properties": { "kind": { "const": "ci" } }
              },
              "minContains": 1
            },
            {
              "contains": {
                "type": "object",
                "required": ["kind"],
                "properties": { "kind": { "const": "live" } }
              },
              "minContains": 1
            }
          ]
        },
        "source_manifest": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["ci", "live"]
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string",
          "minLength": 1
        },
        "success": {
          "type": "object",
          "additionalProperties": false,
          "required": ["exit_status"],
          "properties": {
            "exit_status": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "descriptive_only": {
          "type": "boolean",
          "const": true
        }
      },
      "oneOf": [
        {
          "required": ["command", "success"],
          "not": {
            "anyOf": [
              { "required": ["note"] },
              { "required": ["descriptive_only"] }
            ]
          }
        },
        {
          "required": ["note", "descriptive_only"],
          "not": {
            "anyOf": [
              { "required": ["command"] },
              { "required": ["success"] }
            ]
          }
        }
      ]
    }
  }
}
